{
  "multipart": [
    {   "apply": { "model": "link:block/link_cable_core" }},
    {   "when": { "OR": [{"east": "true"}, {"facing": "east"}] },
      "apply": { "model": "link:block/link_cable_part", "uvlock": false }
    },
    {
      "when": { "facing": "east" },
      "apply": { "model": "link:block/link_connector", "uvlock": false}
    },
    {   "when": { "OR": [{"south": "true"}, {"facing": "south"}] },
      "apply": { "model": "link:block/link_cable_part", "y": 90, "uvlock": false }
    },
    {
      "when": { "facing": "south" },
      "apply": { "model": "link:block/link_connector", "y": 90, "uvlock": false}
    },
    {  "when": { "OR": [{"west": "true"}, {"facing": "west"}] },
      "apply": { "model": "link:block/link_cable_part", "y": 180, "uvlock": false }
    },
    {
      "when": { "facing": "west" },
      "apply": { "model": "link:block/link_connector", "y": 180, "uvlock": false}
    },
    {   "when": { "OR": [{"north": "true"}, {"facing": "north"}] },
      "apply": { "model": "link:block/link_cable_part", "y": 270, "uvlock": false }
    },
    {
      "when": { "facing": "north" },
      "apply": { "model": "link:block/link_connector", "y": 270, "uvlock": false}
    },
    {   "when": { "OR": [{"up": "true"}, {"facing": "up"}] },
      "apply": { "model": "link:block/link_cable_part", "x": 270, "uvlock": false }
    },
    {
      "when": { "facing": "up" },
      "apply": { "model": "link:block/link_connector", "x": 270, "uvlock": false}
    },
    {   "when": { "OR": [{"down": "true"}, {"facing": "down"}] },
      "apply": { "model": "link:block/link_cable_part", "x": 90, "uvlock": false }
    },
    {
      "when": { "facing": "down" },
      "apply": { "model": "link:block/link_connector", "x": 90, "uvlock": false}
    }
  ]
}